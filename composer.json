{
  "name": "kingkool68/super-simple-multisite-sso",
  "description": "Enable single sign on (SSO) across the sites in a WordPress multisite setup.",
  "type": "wordpress-muplugin",
  "support": {
    "issues": "https://github.com/kingkool68/wordpress-super-simple-multisite-sso",
    "source": "https://github.com/kingkool68/wordpress-super-simple-multisite-sso"
  },
  "require": {
    "composer/installers": "^2.0",
    "oidc-wp/openid-connect-generic": "dev-main",
    "joshbetz/wp-openid-connect-server": "dev-add/kid"
  },
  "extra": {
    "installer-paths": {
      "../../plugins/{$name}/": [
        "oidc-wp/openid-connect-generic",
        "joshbetz/wp-openid-connect-server"
      ]
    }
  },
  "homepage": "https://github.com/kingkool68/wordpress-super-simple-multisite-sso",
  "scripts": {
    "post-install-cmd": [
      "cd ../../plugins/openid-connect-generic && [ -f composer.json ] && composer install --no-dev || true",
      "cd ../../plugins/wp-openid-connect-server && [ -f composer.json ] && composer install --no-dev || true"
    ]
  },
  "config": {
    "audit": {
      "ignore": [
        "PKSA-y2cr-5h3j-g3ys"
      ]
    },
    "allow-plugins": {
      "composer/installers": true
    }
  },
  "repositories": [
    {
      "type": "package",
      "package": {
        "name": "oidc-wp/openid-connect-generic",
        "type": "wordpress-plugin",
        "version": "dev-main",
        "source": {
          "type": "git",
          "url": "https://github.com/oidc-wp/openid-connect-generic.git",
          "reference": "main"
        }
      }
    },
    {
      "type": "package",
      "package": {
        "name": "joshbetz/wp-openid-connect-server",
        "type": "wordpress-plugin",
        "version": "dev-add/kid",
        "source": {
          "type": "git",
          "url": "https://github.com/joshbetz/wp-openid-connect-server.git",
          "reference": "add/kid"
        },
        "autoload": {
          "psr-4": {
            "OpenIDConnectServer\\": "src/"
          }
        },
        "require": {
          "ext-json": "*",
          "ext-openssl": "*",
          "bshaffer/oauth2-server-php": "^1.12"
        }
      }
    }
  ]
}
